{
  "version": 2,
  "buildCommand": "echo \"No build required\"",
  "functions": {
    "api/index.js": {
      "includeFiles": "frontend/**",
      "runtime": "nodejs22.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
