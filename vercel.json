{
  "version": 2,
  "buildCommand": "npm install",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x",
      "includeFiles": "**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/api/index.js" }
  ]
}
