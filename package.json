{
  "name": "saludya",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage --passWithNoTests",
    "test:coverage:backend": "jest --config jest.backend.config.cjs --runInBand --coverage --coverageDirectory=coverage/backend --passWithNoTests",
    "test:coverage:frontend": "jest --config jest.frontend.config.cjs --runInBand --coverage --coverageDirectory=coverage/frontend --passWithNoTests",
    "test:coverage:full": "jest --runInBand --coverage --coverageDirectory=coverage/full --passWithNoTests",
    "start": "node api/index.js",
    "dev": "nodemon api/index.js",
    "lint": "echo \"No linter configured\""
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^7.0.6",
    "nodemon": "^3.1.14",
    "pg": "^8.21.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  }
}
